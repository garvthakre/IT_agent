# ── AI Provider ─────────────────────────────────────────────────────────────
# Which LLM to use: groq | anthropic
# groq is free and fast — recommended for development
AI_PROVIDER=groq

# ── Groq API (FREE — get key at console.groq.com) ───────────────────────────
GROQ_API_KEY=your_groq_api_key_here
# Available free models:
#   llama-3.3-70b-versatile  ← recommended (smart + fast)
#   llama-3.1-8b-instant     ← fastest, less capable
#   mixtral-8x7b-32768       ← good alternative
GROQ_MODEL=llama-3.3-70b-versatile

# ── Anthropic (paid) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-opus-4-5

# ── Admin Panel ──────────────────────────────────────────────────────────────
# Only change if your Flask panel runs on a different port
ADMIN_PANEL_URL=http://localhost:5000
